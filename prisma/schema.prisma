// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Models ──────────────────────────────────────────────────────────────────

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

enum EventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  PENALTY_GOAL
  OWN_GOAL
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Tournament {
  id                   String           @id @default(cuid())
  name                 String
  description          String?
  logo                 String?
  status               String           @default("DRAFT") // DRAFT, REGISTRATION, ONGOING, FINISHED
  bracketType          String // ROUND_ROBIN, SINGLE_ELIMINATION
  maxTeams             Int
  minTeams             Int              @default(2)
  registrationDeadline DateTime
  startDate            DateTime
  endDate              DateTime
  createdById          String
  createdBy            User             @relation(fields: [createdById], references: [id])
  teams                TournamentTeam[]
  matches              Match[]
  standings            TournamentStanding[]
  playerStats          PlayerStats[]
  createdAt            DateTime         @default(now())
}

model TournamentTeam {
  id           String     @id @default(cuid())
  tournamentId String
  teamId       String
  status       String     @default("PENDING") // PENDING, APPROVED, REJECTED
  appliedAt    DateTime   @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  team         Team       @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, teamId])
}

model User {
  id                  String       @id @default(cuid())
  email               String       @unique
  password            String
  name                String
  role                String       @default("USER")
  teamId              String?
  team                Team?        @relation("UserTeam", fields: [teamId], references: [id])
  teamCoached         Team?        @relation("TeamCoach")
  accounts            Account[]
  sessions            Session[]
  resetPasswordToken  String?      @unique
  resetPasswordExpiry DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  tournamentsCreated  Tournament[]
  matchesRefereed     Match[]      @relation("MatchReferee")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id           String           @id @default(cuid())
  name         String
  shortName    String
  logo         String?
  primaryColor String           @default("#1a1a2e")
  city         String
  stadium      String
  founded      Int
  description  String?
  players      Player[]
  coaches      User[]           @relation("UserTeam")
  homeMatches  Match[]          @relation("HomeTeam")
  awayMatches  Match[]          @relation("AwayTeam")
  tournamentStandings TournamentStanding[]
  tournaments         TournamentTeam[]
  coachId      String?          @unique
  coach        User?            @relation("TeamCoach", fields: [coachId], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Player {
  id          String       @id @default(cuid())
  firstName   String
  lastName    String
  position    String
  number      Int
  nationality String
  age         Int
  height      String?
  weight      String?
  photo       String?
  teamId      String
  team        Team         @relation(fields: [teamId], references: [id])
  stats       PlayerStats[]
  lineupSlots LineupSlot[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([teamId, number])
}

model PlayerStats {
  id            String     @id @default(cuid())
  playerId      String
  tournamentId  String
  goals         Int        @default(0)
  ownGoals      Int        @default(0)
  yellowCards   Int        @default(0)
  redCards      Int        @default(0)
  matchesPlayed Int        @default(0)
  minutesPlayed Int        @default(0)
  updatedAt     DateTime   @updatedAt
  player        Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournament    Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([playerId, tournamentId])
}

model Match {
  id           String       @id @default(cuid())
  tournamentId String?
  homeTeamId   String
  awayTeamId   String?
  round        Int?
  matchNumber  Int?
  scheduledAt  DateTime?
  tournament   Tournament?  @relation(fields: [tournamentId], references: [id])
  homeTeam     Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore    Int?         @default(0)
  awayScore    Int?         @default(0)
  status       MatchStatus  @default(SCHEDULED)
  kickoff      DateTime
  venue        String
  season       String       @default("2024/25")
  leagueId     String       @default("premier-league")
  minute       Int?         @default(0)
  refereeId    String?
  referee      User?        @relation("MatchReferee", fields: [refereeId], references: [id])
  startedAt    DateTime?
  finishedAt   DateTime?
  lineup       Lineup?
  events       MatchEvent[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Lineup {
  id          String       @id @default(cuid())
  matchId     String       @unique
  match       Match        @relation(fields: [matchId], references: [id])
  slots       LineupSlot[]
  formation   String       @default("4-3-3")
  submittedAt DateTime     @default(now())
}

model LineupSlot {
  id        String  @id @default(cuid())
  lineupId  String
  lineup    Lineup  @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id])
  slotLabel String
  isStarter Boolean @default(true)
  order     Int
}

model MatchEvent {
  id          String    @id @default(cuid())
  matchId     String
  minute      Int
  type        EventType
  playerId    String?
  playerOutId String?   // для замін
  teamId      String
  comment     String?
  createdAt   DateTime  @default(now())
  match       Match     @relation(fields: [matchId], references: [id])
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  String?
  category    String
  tags        String   @default("")
  authorName  String   @default("Editorial Team")
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TournamentStanding {
  id             String     @id @default(cuid())
  tournamentId   String
  teamId         String
  position       Int
  played         Int        @default(0)
  won            Int        @default(0)
  drawn          Int        @default(0)
  lost           Int        @default(0)
  goalsFor       Int        @default(0)
  goalsAgainst   Int        @default(0)
  goalDiff       Int        @default(0)
  points         Int        @default(0)
  updatedAt      DateTime   @updatedAt
  tournament     Tournament @relation(fields: [tournamentId], references: [id])
  team           Team       @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, teamId])
}
